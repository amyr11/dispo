generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id            Int        @id @default(autoincrement())
  userId        String     @map("user_id")
  createdAt     DateTime   @default(now()) @map("createdAt")
  eventName     String     @map("eventName")
  eventStart    DateTime   @map("eventStart")
  eventEnd      DateTime   @map("eventEnd")
  revealAt      DateTime   @map("revealAt")
  attendeeLimit Int        @map("attendeeLimit")
  photoLimit    Int        @map("photoLimit")
  password      String
  attendees     Attendee[]

  @@map("events")
}

model Attendee {
  id          BigInt   @unique @default(autoincrement()) @db.BigInt
  nickname    String
  fingerprint String
  joinedAt    DateTime @default(now()) @map("joinedAt") @db.Timestamptz(6)
  eventId     Int      @map("eventId")
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([eventId, fingerprint])
  @@unique([eventId, nickname])
  @@map("attendees")
}

model Photo {
  id          BigInt   @id @default(autoincrement()) @db.BigInt
  deleted     Boolean  @default(false)
  takenAt     DateTime @map("takenAt") @db.Timestamptz(6)
  eventId     BigInt   @map("eventId") @db.BigInt
  attendeeId  BigInt   @map("attendeeId") @db.BigInt
  storagePath String   @map("storagePath")

  @@map("photos")
}
